# Copy to .env and update values.

# PostgreSQL used by backend
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yolofarm_db
DB_USER=postgres
DB_PASSWORD=your_password

# Adafruit IO credentials
ADAFRUIT_USERNAME=your_adafruit_username
ADAFRUIT_IO_KEY=your_adafruit_io_key
ADAFRUIT_BROKER=io.adafruit.com
ADAFRUIT_PORT=8883

# Runtime behavior
SYNC_SECONDS=5
SIM_PROFILES_FILE=profiles.json
LOG_LEVEL=INFO
