@startuml
entity "User" as users {
  * id : UUID <<PK>>
  * username : VARCHAR(50)
  * role : RoleEnum [ADMIN, FARMER]
}

entity "Notification" as notifications {
  * id : UUID <<PK>>
  * user_id : UUID <<FK>>
  * message : TEXT
  * is_read : BOOLEAN
  * created_at : TIMESTAMP
}

entity "Farm" as farms {
  * id : UUID <<PK>>
  * owner_id : UUID <<FK>>
  * name : VARCHAR(100)
}

entity "DeviceModel" as models {
  * id : UUID <<PK>>
  * model_name : VARCHAR(100)
  * device_type : DeviceTypeEnum [SENSOR, ACTUATOR]
  * metric_type : MetricTypeEnum [TEMP, HUMIDITY, SOIL_MOISTURE, PUMP, LIGHT]
  * manufacturer : VARCHAR(100)
}

entity "Device" as devices {
  * id : UUID <<PK>>
  * farm_id : UUID <<FK>>
  * model_id : UUID <<FK>>
  * name : VARCHAR(100)
  * status : DeviceStatusEnum [PENDING, ACTIVE, REJECTED, PENDING_REMOVAL]
  adafruit_feed_key : VARCHAR(100) <<Nullable>>
  connection_status : ConnectionStatusEnum [ONLINE, OFFLINE]
  last_seen : TIMESTAMP
  operating_mode : OperatingModeEnum [AUTO, MANUAL]
}

entity "Rule" as rules {
  * id : UUID <<PK>>
  * farm_id : UUID <<FK>>
  * rule_type : RuleTypeEnum [CONDITION, SCHEDULE]
  trigger_device_id : UUID <<FK>> <<Nullable>>
  operator : VARCHAR(5) <<Nullable>>
  threshold_value : FLOAT <<Nullable>>
  cron_expression : VARCHAR(100) <<Nullable>>
  * action_device_id : UUID <<FK>>
  * action_command : ActionCommandEnum [ON, OFF]
  * is_active : BOOLEAN
}

users "1" -- "0..*" farms : owns
users "1" -- "0..*" notifications : receives
models "1" -- "0..*" devices : template_for
farms "1" -- "0..*" devices : contains
farms "1" -- "0..*" rules : has
@enduml