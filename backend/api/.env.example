# Copy this file to .env and fill real values before running locally.
# Do NOT commit .env (contains secrets).

DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
JWT_SECRET_KEY=your_base64_jwt_secret
ADAFRUIT_USERNAME=your_adafruit_username
ADAFRUIT_IO_KEY=your_adafruit_io_key

# Optional (has default in application.yml)
ADAFRUIT_BROKER_URL=ssl://io.adafruit.com:8883
WS_ALLOWED_ORIGINS=http://localhost:3000
